# Copy this file to .env for local development. Keep real secrets out of Git.

# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
LOCAL_APP_URL=http://127.0.0.1:3000
INTERNAL_APP_URL=http://127.0.0.1:3000
NODE_ENV=development
LOG_LEVEL=info

# Auth and encryption
JWT_SECRET=change_me_to_a_random_64_char_secret
ENCRYPTION_KEY=change_me_to_a_64_char_hex_key
DEFAULT_ADMIN_PASSWORD=change_me_admin_password

# Database
DATABASE_PATH=./data/huoziwriter.db
# DATABASE_URL=postgresql://huoziwriter:password@localhost:5432/huoziwriter
# DATABASE_SCHEMA=public

# Scheduler and worker services
SCHEDULER_SERVICE_URL=http://127.0.0.1:3000
SCHEDULER_SERVICE_TOKEN=
SCHEDULER_SHARED_TOKEN=
WRITING_EVAL_AGENT_STRATEGIES=
WRITING_EVAL_CASE_CONCURRENCY=2

# AI provider settings
# OpenAI: 发布前审核链路，包括事实核查、文笔润色、语言守卫、发布守门、节奏一致性评估；也作为截图理解、排版提取等 Gemini 场景的兜底模型。
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Cover image engine local override. When set, image generation prefers these env values over admin DB config.
# COVER_IMAGE_PROVIDER=openai
# COVER_IMAGE_BASE_URL=https://api.openai.com/v1
# COVER_IMAGE_MODEL=gpt-image-2
# COVER_IMAGE_API_KEY=
# COVER_IMAGE_ENABLED=true

# Anthropic: 重写作与策略链路，包括研究简报、受众画像、大纲规划、标题/开头优化、正文生成、深度写作、策略卡初稿与反写回。
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# Gemini / Google AI: 多模态与信息提取链路，包括碎片提纯、截图视觉笔记、风格提取、选题补证、选题库生成、IMA 爆款规律提炼、排版结构提取与选题裂变。
GEMINI_API_KEY=
GOOGLE_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Optional per-scene model overrides. Keys are scene codes in ai_model_routes.
# 可按业务场景覆盖模型：articleWrite/deepWrite=正文生成，researchBrief=研究简报，
# fragmentDistill=碎片提纯，visionNote=截图理解，factCheck/prosePolish/publishGuard=发布前审核。
# AI_MODEL_ROUTES_JSON={"articleWrite":{"primaryModel":"claude-sonnet-4-6","fallbackModel":"gpt-5.4-mini"},"factCheck":{"primaryModel":"gpt-5.4-mini","fallbackModel":"gpt-5.4-nano"}}
AI_MODEL_ROUTES_JSON=

# External integrations
IMA_OPENAPI_BASE_URL=https://ima.qq.com
RESEARCH_SOURCE_SEARCH_ENDPOINT=
WECHAT_DEFAULT_TIMEOUT_MS=10000

# Build and test controls
NEXT_OUTPUT_MODE=
NEXT_DIST_DIR=
PLAYWRIGHT_CHANNEL=
STORYBOOK_A11Y_BROWSER_CHANNEL=
WRITING_EVAL_LOCAL_MOCK=
