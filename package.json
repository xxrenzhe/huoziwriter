{
  "name": "huoziwriter",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.23.0",
  "scripts": {
    "dev": "pnpm --filter @huoziwriter/web dev",
    "build": "pnpm --filter @huoziwriter/web build",
    "start": "pnpm --filter @huoziwriter/web start",
    "type-check": "pnpm --filter @huoziwriter/web type-check",
    "db:init": "pnpm --filter @huoziwriter/web db:init",
    "verify": "pnpm type-check && pnpm build && python3 -m py_compile apps/worker-py/main.py apps/worker-py/scheduler.py apps/worker-py/queue_runtime.py && node scripts/check-standalone-runtime-init.mjs",
    "test:e2e": "pnpm build && playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  }
}
